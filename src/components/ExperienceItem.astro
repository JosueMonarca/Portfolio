---
interface Props{
    date:string;
    title:string;
    description:string
}

const { date, title, description } = Astro.props
---

<li class="mb-10 ms-4">
    <div class="absolute w-3 h-3 bg-neutral-quaternary rounded-full mt-1.5 -start-1.5 border border-buffer"></div>
    <time class="text-sm font-normal leading-none text-body">{date}</time>
    <h3 class="text-lg font-semibold text-heading my-2">{title}</h3>
    <p class="text-base font-normal text-body">{description}</p>

    <slot />
</li>